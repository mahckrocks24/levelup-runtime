# ── LevelUp Runtime — Environment Variables ───────────────────────────────
# Copy this to .env for local development.
# On Railway: set these in the Railway dashboard under Variables.

# ── Redis ──────────────────────────────────────────────────────────────────
# Railway provides this automatically when you add the Redis plugin.
# It will appear as REDIS_URL in your Railway environment.
REDIS_URL=redis://localhost:6379

# ── WordPress Communication ────────────────────────────────────────────────
# The shared secret generated by the WordPress plugin.
# Copy from: WP Admin → LevelUp Core → Runtime Configuration → Shared Secret
WP_SECRET=paste_your_wordpress_shared_secret_here

# The WordPress REST callback URL.
# Copy from: WP Admin → LevelUp Core → Runtime Configuration → WordPress Callback URL
# Example: https://yoursite.com/wp-json/levelup/v1/core/task-result
WP_CALLBACK_URL=https://yoursite.com/wp-json/levelup/v1/core/task-result

# ── Server ─────────────────────────────────────────────────────────────────
# Railway sets PORT automatically. Leave as 3000 for local dev.
PORT=3000

# ── Environment ────────────────────────────────────────────────────────────
NODE_ENV=production
